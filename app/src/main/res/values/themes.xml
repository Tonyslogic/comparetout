<resources>
    <!-- Base application theme. -->
    <style name="Theme.comparetout" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- UI2 theme: same colours, no built-in ActionBar (Compose TopAppBar handles the title). -->
    <style name="Theme.comparetout.UI2" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!--
        Launch theme used by LaunchActivity. The AndroidX SplashScreen API
        backports Android 12's window splash to API 23+, so older devices
        also see a stable launch image while LaunchActivity reads the
        use_ui2 flag and routes to the right home screen. postSplashScreenTheme
        is the UI2 theme because that is the dominant routing target — for
        the legacy fallback the brief visual mismatch is acceptable.
    -->
    <style name="Theme.comparetout.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/purple_500</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.comparetout.UI2</item>
    </style>
</resources>