<network-security-config xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="AcceptsUserCertificates,InsecureBaseConfiguration">
    <!--
      Cleartext + user-CA trust are required so the importer can reach
      a self-hosted Home Assistant on the local LAN, which typically
      uses plain HTTP and/or a user-installed CA. The narrower
      domain-config approach would require knowing each user's HA hostname
      in advance, which we don't.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust preinstalled CAs -->
            <certificates src="system"/>
            <!-- Additionally trust user added CAs -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>